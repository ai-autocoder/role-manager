# Application settings
APP_NAME=Role Manager API
APP_VERSION=0.1.0
DEBUG=true

# Server settings
HOST=0.0.0.0
PORT=8000

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# Event ingestion
DEFAULT_EVENT_PRODUCER=api

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=role_manager.events.topic
RABBITMQ_COMPUTE_QUEUE=role_manager.assignments.compute
RABBITMQ_COMPUTE_BINDING_KEY=#
RABBITMQ_DLQ_QUEUE=role_manager.assignments.dlq
RABBITMQ_DLQ_ROUTING_KEY=events.dlq
RABBITMQ_CONNECT_TIMEOUT_SECONDS=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
PROCESSED_EVENT_TTL_SECONDS=604800

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DATABASE=role_manager

# Worker
WORKER_PREFETCH_COUNT=10

# Database settings (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=role_manager_dev
